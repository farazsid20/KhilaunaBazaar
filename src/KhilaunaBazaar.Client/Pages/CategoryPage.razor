@page "/category/{Slug}"
@inject ApiClient Api
@inject CartService Cart
@inject NavigationManager Nav

<PageTitle>@(_category?.Name ?? Slug) - KhilaunaBazaar</PageTitle>

@if (_category != null)
{
    <section class="py-5 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="container">
            <h1 class="display-5 fw-bold mb-3"><i class="fas @_category.IconClass"></i> @_category.Name</h1>
            <p class="lead text-white-50">@_category.Description</p>
        </div>
    </section>
}

<section class="py-5">
    <div class="container">
        @if (_loading)
        {
            <p class="text-center text-muted">Loading...</p>
        }
        else if (_products.Count == 0)
        {
            <div class="alert alert-warning">No products found in this category.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in _products)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="img-placeholder" style="padding: 0; overflow: hidden;">
                                <img src="@product.ImageUrl" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title">@product.Name</h6>
                                <p class="text-muted small flex-grow-1">@product.Description</p>
                                <div class="mb-2"><span class="badge bg-success">★ @product.Rating</span></div>
                                <h5 class="text-primary mb-3">₹@product.Price.ToString("F2")</h5>
                                <div class="d-grid gap-2">
                                    <button class="btn btn-primary btn-sm" @onclick="() => AddToCart(product)">
                                        <i class="fas fa-shopping-cart"></i> Add to Cart
                                    </button>
                                    <NavLink href="@($"/product/{product.Id}")" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-eye"></i> View Details
                                    </NavLink>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public string Slug { get; set; } = "";

    private Models.Category? _category;
    private List<Product> _products = new();
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Slug)) return;
        _loading = true;
        await Cart.LoadAsync();
        try
        {
            _category = await Api.GetCategoryBySlugAsync(Slug);
            _products = (await Api.GetProductsByCategoryAsync(Slug)).ToList();
        }
        catch
        {
            _category = null;
            _products = new();
        }
        _loading = false;
    }

    private async Task AddToCart(Product p)
    {
        await Cart.AddAsync(p.Id, p.Name, p.Price, 1);
    }
}
