@page "/"
@inject ApiClient Api
@inject CartService Cart
@inject NavigationManager Nav

<PageTitle>KhilaunaBazaar - Kids Toys & Games</PageTitle>

<section class="hero-section text-white text-center py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">Welcome to KhilaunaBazaar!</h1>
        <p class="lead mb-4">Discover the most fun and exciting toys for kids of all ages</p>
        <a href="#categories" class="btn btn-light btn-lg">Shop Now <i class="fas fa-arrow-down ms-2"></i></a>
    </div>
</section>

<section id="categories" class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5 fw-bold">Shop by Category</h2>
        <div class="row g-4">
            @foreach (var cat in _categories)
            {
                <div class="col-md-6 col-lg-3">
                    <NavLink href="@($"/category/{cat.Slug}")" class="text-decoration-none">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="img-placeholder bg-primary" style="padding: 0; overflow: hidden;">
                                <img src="@GetCategoryImage(cat.Slug)" alt="@cat.Name" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                            </div>
                            <div class="card-body text-center">
                                <h5 class="card-title"><i class="fas @cat.IconClass text-primary"></i> @cat.Name</h5>
                                <p class="text-muted small">@cat.Description</p>
                            </div>
                        </div>
                    </NavLink>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-5 fw-bold">Featured Products</h2>
        @if (_loading)
        {
            <p class="text-center text-muted">Loading...</p>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in _featured)
                {
                    <div class="col-md-6 col-lg-3">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="img-placeholder" style="padding: 0; overflow: hidden;">
                                <img src="@product.ImageUrl" alt="@product.Name" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                            </div>
                            <div class="card-body">
                                <h6 class="card-title">@product.Name</h6>
                                <div class="mb-2"><span class="badge bg-success">★ @product.Rating</span></div>
                                <h5 class="text-primary mb-3">₹@product.Price.ToString("F2")</h5>
                                <button class="btn btn-primary btn-sm w-100" @onclick="() => AddToCart(product)">
                                    <i class="fas fa-shopping-cart"></i> Add to Cart
                                </button>
                                <NavLink href="@($"/product/{product.Id}")" class="btn btn-outline-primary btn-sm w-100 mt-2">View Details</NavLink>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 text-center">
                <i class="fas fa-shipping-fast fa-3x text-primary mb-3"></i>
                <h5>Fast Shipping</h5>
                <p class="text-muted">Quick delivery to your doorstep</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <i class="fas fa-undo fa-3x text-primary mb-3"></i>
                <h5>Easy Returns</h5>
                <p class="text-muted">30-day return policy</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <i class="fas fa-lock fa-3x text-primary mb-3"></i>
                <h5>Secure Payment</h5>
                <p class="text-muted">100% safe transactions</p>
            </div>
            <div class="col-md-6 col-lg-3 text-center">
                <i class="fas fa-headset fa-3x text-primary mb-3"></i>
                <h5>24/7 Support</h5>
                <p class="text-muted">Dedicated customer service</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5 text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h3 class="mb-3">Subscribe to Our Newsletter</h3>
                <p>Get exclusive deals and updates on new toys!</p>
            </div>
            <div class="col-lg-6">
                <div class="d-flex gap-2">
                    <input type="email" class="form-control" placeholder="Enter your email" @bind="_newsletterEmail" />
                    <button type="button" class="btn btn-light" @onclick="Subscribe">Subscribe</button>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<Category> _categories = new();
    private List<Product> _featured = new();
    private bool _loading = true;
    private string _newsletterEmail = "";

    protected override async Task OnInitializedAsync()
    {
        await Cart.LoadAsync();
        try
        {
            _categories = (await Api.GetCategoriesAsync()).ToList();
            _featured = (await Api.GetFeaturedProductsAsync(4)).ToList();
        }
        catch (Exception)
        {
            // Fallback if API not running
            _categories = new List<Category>();
            _featured = new List<Product>();
        }
        _loading = false;
    }

    private string GetCategoryImage(string slug) => slug switch
    {
        "action-figures" => "https://via.placeholder.com/400x300/667eea/ffffff?text=Action+Figures",
        "dolls" => "https://via.placeholder.com/400x300/4D96FF/ffffff?text=Dolls",
        "building-blocks" => "https://via.placeholder.com/400x300/FFD93D/000000?text=Building+Blocks",
        "outdoor-toys" => "https://via.placeholder.com/400x300/6BCB77/ffffff?text=Outdoor",
        "board-games" => "https://via.placeholder.com/400x300/9370DB/ffffff?text=Board+Games",
        "stuffed-animals" => "https://via.placeholder.com/400x300/FF69B4/ffffff?text=Stuffed",
        _ => "https://via.placeholder.com/400x300/667eea/ffffff?text=Category"
    };

    private async Task AddToCart(Product p)
    {
        await Cart.AddAsync(p.Id, p.Name, p.Price, 1);
    }

    private void Subscribe()
    {
        // Placeholder - could call API
    }
}
