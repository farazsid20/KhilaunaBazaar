@page "/contact"
@inject ApiClient Api

<PageTitle>Contact Us - KhilaunaBazaar</PageTitle>

<section class="py-5 bg-light">
    <div class="container">
        <h1 class="display-5 fw-bold mb-2"><i class="fas fa-headset text-primary"></i> Contact Us</h1>
        <p class="lead text-muted">Get in touch with KhilaunaBazaar - We're here to help!</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-5 mb-5">
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-map-marker-alt fa-3x text-primary mb-3"></i>
                        <h5 class="card-title mb-3">Our Address</h5>
                        <p class="text-muted small">
                            Cognionix Innovations Pvt. Ltd.,<br />
                            1st Floor, Samruddhi Vertex, Mylasandra, Bengaluru – 560068, Karnataka, India
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-phone fa-3x text-success mb-3"></i>
                        <h5 class="card-title mb-3">Phone</h5>
                        <p class="text-muted"><a href="tel:+917090887766" class="text-decoration-none">+91-7090887766</a></p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-envelope fa-3x text-info mb-3"></i>
                        <h5 class="card-title mb-3">Email</h5>
                        <p class="text-muted"><a href="mailto:support@khilaunabazaar.com" class="text-decoration-none">support@khilaunabazaar.com</a></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm border-0">
                    <h5 class="card-header bg-light"><i class="fas fa-comment text-primary me-2"></i> Send us a Message</h5>
                    <div class="card-body">
                        <EditForm Model="_model" OnValidSubmit="Submit" Context="form">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <InputText class="form-control" @bind-Value="_model.FullName" />
                                <ValidationMessage For="@(() => _model.FullName)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <InputText class="form-control" type="email" @bind-Value="_model.Email" />
                                <ValidationMessage For="@(() => _model.Email)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone</label>
                                <InputText class="form-control" type="tel" @bind-Value="_model.Phone" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Subject</label>
                                <InputText class="form-control" @bind-Value="_model.Subject" />
                                <ValidationMessage For="@(() => _model.Subject)" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Message</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="_model.Message" />
                            </div>
                            @if (!string.IsNullOrEmpty(_message))
                            {
                                <div class="alert @(_success ? "alert-success" : "alert-danger") mb-3">@_message</div>
                            }
                            <button type="submit" class="btn btn-primary w-100" disabled="@_sending">
                                @if (_sending) { <span>Sending...</span> } else { <span><i class="fas fa-paper-plane me-2"></i>Send Message</span> }
                            </button>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private ContactRequest _model = new();
    private string _message = "";
    private bool _success;
    private bool _sending;

    private async Task Submit()
    {
        _sending = true;
        _message = "";
        try
        {
            var ok = await Api.SubmitContactAsync(_model);
            _success = ok;
            _message = ok ? "Thank you! Your message has been sent. We will get back to you soon." : "Something went wrong. Please try again.";
            if (ok) _model = new ContactRequest();
        }
        catch (Exception ex)
        {
            _success = false;
            _message = "Failed to send: " + ex.Message;
        }
        _sending = false;
    }
}
